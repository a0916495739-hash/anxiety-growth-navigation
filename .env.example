# PostgreSQL (Docker)
POSTGRES_USER=appuser
POSTGRES_PASSWORD=apppassword
POSTGRES_DB=anxiety_navigator

# pgAdmin (Docker)
PGADMIN_EMAIL=admin@local.dev
PGADMIN_PASSWORD=admin

# Backend (本機執行)
DATABASE_URL=postgresql://appuser:apppassword@localhost:5432/anxiety_navigator
JWT_SECRET=change_this_to_a_long_random_secret
PORT=3001

# Frontend (Vite) — 本機開發不需設定，只有部署時才需要
# VITE_API_URL=https://your-backend.railway.app/api
# FRONTEND_URL=https://your-app.vercel.app

# Email (忘記密碼功能) — 以 Gmail 為例
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your@gmail.com
# SMTP_PASS=your-app-password   # Gmail 需使用「應用程式密碼」而非登入密碼
